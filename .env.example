# ============================================================
# iFlow 心流模型配置（推荐！已配置）
# 可用模型: qwen3-max, qwen3-coder-plus, qwen3-vl-plus, 
#          qwen3-235b-a22b-thinking-2507, deepseek-v3.2, 
#          kimi-k2, kimi-k2-0905, iflow-rome-30ba3b
# ============================================================
OPENAI_API_KEY=your_iflow_api_key_here
OPENAI_BASE_URL=https://apis.iflow.cn/v1

# 提供商选择: openai, zhipuai, deepseek, qwen, ollama
provider=openai

# 模型选择（根据任务类型选择不同模型）
deep_think_model=qwen3-max        # 复杂推理任务（Agent分析、辩论、决策）
quick_think_model=deepseek-v3.2   # 快速任务（意图识别、问答）

# ============================================================
# RAG 配置
# ============================================================

# Embedding 模型（用于向量检索）
# 可选: shibing624/text2vec-base-chinese, BAAI/bge-small-zh-v1.5
EMBEDDING_MODEL=shibing624/text2vec-base-chinese

# 向量数据库路径
VECTOR_STORE_PATH=./data/chroma

# 知识图谱存储路径
KNOWLEDGE_GRAPH_PATH=./data/knowledge_graph

# ============================================================
# 其他 LLM 提供商（备选）
# ============================================================

# 智谱AI - GLM-4-Flash模型免费
# ZHIPUAI_API_KEY=your_zhipuai_api_key_here

# DeepSeek（新用户有免费额度）
# DEEPSEEK_API_KEY=your_deepseek_api_key_here
# DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# 阿里云通义千问（有免费额度）
# DASHSCOPE_API_KEY=your_dashscope_api_key_here

# Ollama 本地模型
# OLLAMA_BASE_URL=http://localhost:11434

# ============================================================
# 应用配置
# ============================================================

# 日志级别: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# 启用记忆系统
ENABLE_MEMORY=true

# 最大辩论轮数
MAX_DEBATE_ROUNDS=2